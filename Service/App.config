<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<appSettings>
		<add key="ServerDataPath" value="ServerData" />
		<add key="F_threshold" value="0.5" />
		<add key="FFT_threshold" value="0.5" />
		<add key="AverageDeviationPercent" value="25" />
	</appSettings>

	<system.serviceModel>

		<bindings>
			<netTcpBinding>
				<binding name="SmartGridTcpBinding"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 maxBufferSize="65536"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00"
						 sendTimeout="00:05:00"
						 receiveTimeout="00:10:00">
					<security mode="None" />
				</binding>
			</netTcpBinding>
		</bindings>

		<services>
			<service name="Service.SmartGridService">

				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:4000/" />
					</baseAddresses>
				</host>

				<endpoint
					address="SmartGrid"
					binding="netTcpBinding"
					bindingConfiguration="SmartGridTcpBinding"
					contract="Common.IService" />

			</service>
		</services>

		<behaviors>
			<serviceBehaviors>
				<behavior>
					<serviceDebug includeExceptionDetailInFaults="true" />
				</behavior>
			</serviceBehaviors>
		</behaviors>

	</system.serviceModel>
</configuration>