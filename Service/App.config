<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<appSettings>
		<add key="ServerDataPath" value="serverData" />
		<add key="F_threshold" value="0.5" />
		<add key="FFT_threshold" value="0.5" />
		<add key="AverageDeviationPercent" value="25" />
	</appSettings>

	<system.serviceModel>
		<services>
			<service name="Service.SmartGridService">
				<endpoint
				  address="net.tcp://localhost:4000/SmartGrid"
				  binding="netTcpBinding"
				  bindingConfiguration="SmartGridTcpBinding"
				  contract="Common.IService" />

				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:4000/SmartGrid" />
					</baseAddresses>
				</host>
			</service>
		</services>

		<bindings>
			<netTcpBinding>
				<binding
				  name="SmartGridTcpBinding"
				  transferMode="Buffered"
				  maxReceivedMessageSize="10485760"
				  sendTimeout="00:05:00"
				  receiveTimeout="00:10:00"
				  openTimeout="00:01:00"
				  closeTimeout="00:01:00">
					<security mode="None" />
				</binding>
			</netTcpBinding>
		</bindings>
	</system.serviceModel>

</configuration>