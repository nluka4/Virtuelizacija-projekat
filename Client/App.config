<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<appSettings>
		<add key="DatasetPath" value="smart_grid_dataset.csv" />
	</appSettings>

	<system.serviceModel>

		<bindings>
			<netTcpBinding>
				<binding name="SmartGridTcpBinding"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 maxBufferSize="65536"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00"
						 sendTimeout="00:05:00"
						 receiveTimeout="00:10:00">
					<security mode="None" />
				</binding>
			</netTcpBinding>
		</bindings>

		<client>
			<endpoint
				name="SmartGrid"
				address="net.tcp://localhost:4000/SmartGrid"
				binding="netTcpBinding"
				bindingConfiguration="SmartGridTcpBinding"
				contract="Common.IService" />
		</client>

	</system.serviceModel>
</configuration>